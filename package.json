{
	"name": "@superbuilders/slog",
	"version": "4.0.5",
	"description": "Simple structured logging library",
	"module": "dist/index.js",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && tsgo -p tsconfig.build.json",
		"typecheck": "tsgo --noEmit",
		"lint": "biome check .",
		"test": "pnpm run build && node --test src/index.test.ts",
		"prepublishOnly": "pnpm run build"
	},
	"keywords": [
		"logging",
		"structured-logging",
		"performance",
		"slog",
		"high-performance"
	],
	"author": "Bjorn Pagen",
	"license": "0BSD",
	"repository": {
		"type": "git",
		"url": "https://github.com/superbuilders/slog"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0-beta.5",
		"@types/node": "^26.1.0",
		"@typescript/native-preview": "7.0.0-dev.20260702.3",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"typescript": "^5.8.3"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "pnpm@11.9.0",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"imports": {
		"#*.ts": {
			"types": "./src/*.ts",
			"default": "./dist/*.js"
		}
	}
}
